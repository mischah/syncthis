{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/cli",
    "typecheck": "npm run typecheck -w packages/shared && npm run typecheck -w packages/cli && npx tsc --noEmit -p packages/gui/tsconfig.json",
    "test": "npm run test -w packages/cli && npm run test -w packages/gui",
    "dev": "npm run dev -w packages/cli",
    "dev:cli": "npm run dev -w packages/cli",
    "dev:gui": "npm run dev -w packages/gui",
    "start:gui": "npm run start -w packages/gui",
    "make:gui": "npm run make -w packages/gui",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky",
    "release": "npm run release -w packages/cli",
    "release:preview": "npm run release:preview -w packages/cli"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "np": "11.0.3"
  },
  "lint-staged": {
    "*.{ts,js,json}": [
      "biome format --write --no-errors-on-unmatched",
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
