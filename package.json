{
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "npm run build -w packages/cli",
    "typecheck": "npm run typecheck -w packages/cli",
    "test": "npm run test -w packages/cli",
    "dev": "npm run dev -w packages/cli",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky",
    "release": "npm run release -w packages/cli",
    "release:preview": "npm run release:preview -w packages/cli"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "husky": "9.1.7",
    "lint-staged": "16.3.2",
    "np": "11.0.2"
  },
  "lint-staged": {
    "*.{ts,js,json}": [
      "biome format --write --no-errors-on-unmatched",
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
