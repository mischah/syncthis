{
  "name": "syncthis",
  "version": "0.1.0",
  "description": "Automatic directory synchronization via Git",
  "type": "module",
  "bin": {
    "syncthis": "./dist/cli.js"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["git", "sync", "cli", "obsidian", "backup", "auto-commit"],
  "license": "MIT",
  "dependencies": {
    "meow": "^13.0.0",
    "simple-git": "^3.0.0",
    "croner": "^8.0.0"
  },
  "devDependencies": {
    "tsdown": "^0.20.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0",
    "execa": "^9.0.0"
  }
}
