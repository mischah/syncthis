{
  "name": "syncthis",
  "repository": "mischah/syncthis",
  "author": {
    "name": "Michael Kühnel",
    "email": "mail@michael-kuehnel.de",
    "url": "http://michael-kuehnel.de"
  },
  "version": "1.1.1",
  "description": "Automatic directory synchronization via Git",
  "type": "module",
  "bin": {
    "syncthis": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/cli.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build && cp ./README.md ./dist/README.md",
    "version": "npm pkg set version=$npm_package_version --prefix ../shared && npm pkg set version=$npm_package_version --prefix ../gui && git add ../shared/package.json ../gui/package.json",
    "release": "np",
    "release:preview": "np --preview"
  },
  "keywords": [
    "git",
    "sync",
    "cli",
    "obsidian",
    "backup",
    "auto-commit"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "1.1.0",
    "chalk": "5.6.2",
    "croner": "10.0.1",
    "diff": "8.0.3",
    "execa": "9.6.1",
    "meow": "14.1.0",
    "simple-git": "3.33.0"
  },
  "devDependencies": {
    "@syncthis/shared": "*",
    "@types/node": "25.5.2",
    "@vitest/coverage-v8": "4.1.3",
    "tsdown": "0.21.7",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.3"
  },
  "np": {
    "contents": "dist"
  }
}
