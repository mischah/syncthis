{
  "name": "syncthis",
  "repository": "mischah/syncthis",
  "author": {
    "name": "Michael Kühnel",
    "email": "mail@michael-kuehnel.de",
    "url": "http://michael-kuehnel.de"
  },
  "version": "0.1.2",
  "description": "Automatic directory synchronization via Git",
  "type": "module",
  "bin": {
    "syncthis": "./dist/cli.js"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/cli.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "prerelease": "npm run build",
    "release": "np",
    "prerelease:preview": "npm run prerelease",
    "release:preview": "np --preview"
  },
  "keywords": ["git", "sync", "cli", "obsidian", "backup", "auto-commit"],
  "license": "MIT",
  "dependencies": {
    "croner": "^8.0.0",
    "meow": "^13.0.0",
    "simple-git": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "execa": "^9.0.0",
    "tsdown": "^0.20.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "np": {
    "contents": "dist"
  }
}
