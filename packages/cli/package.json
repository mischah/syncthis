{
  "name": "syncthis",
  "repository": "mischah/syncthis",
  "author": {
    "name": "Michael Kühnel",
    "email": "mail@michael-kuehnel.de",
    "url": "http://michael-kuehnel.de"
  },
  "version": "0.6.3",
  "description": "Automatic directory synchronization via Git",
  "type": "module",
  "bin": {
    "syncthis": "./dist/cli.js"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/cli.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build && cp ../../README.md ./README.md",
    "postpack": "rm ./README.md",
    "release": "np",
    "prerelease:preview": "npm run prerelease",
    "release:preview": "np --preview"
  },
  "keywords": ["git", "sync", "cli", "obsidian", "backup", "auto-commit"],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "1.1.0",
    "chalk": "5.6.2",
    "croner": "10.0.1",
    "diff": "8.0.3",
    "execa": "9.6.1",
    "meow": "14.1.0",
    "simple-git": "3.32.3"
  },
  "devDependencies": {
    "@types/node": "25.4.0",
    "@vitest/coverage-v8": "4.0.18",
    "tsdown": "0.21.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "np": {
    "contents": "dist"
  }
}
